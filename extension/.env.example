# =============================================================================
# EmailTrack Extension — Environment Variables
# =============================================================================
# COPY THIS FILE TO .env AND EDIT WITH YOUR VALUES:
#   cp .env.example .env
#
# These values are injected at BUILD TIME by Vite (import.meta.env.VITE_*)
# After changing, rebuild the extension: npm run build
# =============================================================================

# ── Backend API URL ──────────────────────────────────────────────────────────
# The URL of your EmailTrack backend server
# Local Development: http://localhost:3000
# Production:        https://emailtrack.yourdomain.com
VITE_API_URL=http://localhost:3000

# ── Google OAuth Client ID ───────────────────────────────────────────────────
# Must match GOOGLE_CLIENT_ID in the backend .env
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── Debug Logging ────────────────────────────────────────────────────────────
# Enable verbose console logging in the extension popup
# Set to "false" for production builds (console.* is also stripped by Vite)
VITE_DEBUG=false
