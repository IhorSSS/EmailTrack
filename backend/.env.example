# =============================================================================
# EmailTrack Backend — Environment Variables
# =============================================================================
# COPY THIS FILE TO .env AND EDIT WITH YOUR VALUES:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
# If using Docker Compose, DATABASE_URL is constructed automatically.
# For local development (without Docker), uncomment and set:
# DATABASE_URL="postgresql://emailtrack:your_password@localhost:5432/emailtrack?schema=public"

# Database Password — used by Docker Compose to build DATABASE_URL
# Minimum 16 characters recommended
DB_PASSWORD=your_secure_password_here_min_16_chars

# ── Security & Encryption ────────────────────────────────────────────────────
# JWT Secret for session signing
# Minimum 32 characters. Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here_min_32_chars

# Encryption Key for AES-256-CBC (at-rest encryption of email content)
# MUST be exactly 32 characters. Generate with: openssl rand -hex 16
ENCRYPTION_KEY=your_encryption_key_here_min_32_chars

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Google OAuth Client ID from Google Cloud Console
# Must match VITE_GOOGLE_CLIENT_ID in the extension .env
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── Chrome Extension ─────────────────────────────────────────────────────────
# Chrome Extension ID — used for CORS origin whitelist
# Find it at chrome://extensions after loading your unpacked extension
EXTENSION_ID=your_chrome_extension_id_here

# ── Server ───────────────────────────────────────────────────────────────────
# Port the backend listens on
PORT=3000

# Public-facing base URL (used for generating tracking pixel URLs)
# Required in production. Example: https://emailtrack.yourdomain.com
BASE_URL=http://localhost:3000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins (optional)
# In development, localhost:3000 and localhost:5173 are allowed by default
# In production, set explicitly:
# CORS_ALLOWED_ORIGINS=https://your-frontend.com

# ── Rate Limiting ────────────────────────────────────────────────────────────
# Comma-separated IPs to exclude from rate limiting (optional)
# Default: 127.0.0.1
# RATE_LIMIT_ALLOW_LIST=127.0.0.1,10.0.0.1

# ── Docker / Reverse Proxy (Optional) ───────────────────────────────────────
# These are only needed if using nginx-proxy + Let's Encrypt in Docker
# VIRTUAL_HOST=emailtrack.yourdomain.com
# LETSENCRYPT_EMAIL=admin@yourdomain.com
